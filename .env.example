# Copy to .env and fill in real values before running.

# PostgreSQL connection string used by Alembic and Django ORM.
# For local dev (pooler on 5432 or PgBouncer on 6543):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/snb_backend

# Django secret key (generate a new one for production)
SECRET_KEY=change-me-in-production

# Set to False in production
DEBUG=True

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Supabase credentials (used by auth_ext for JWKS verification)
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Redis URL for Django Channels
REDIS_URL=redis://localhost:6379/0
