# Copy to .env and fill in real values before running.

# ---------------------------------------------------------------------------
# PostgreSQL connection string used by Alembic and Django ORM.
# ---------------------------------------------------------------------------
# Local dev (Docker / native Postgres):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/snb_backend
#
# Hosted Supabase — use the Supavisor pooler. The direct host
# (`db.<ref>.supabase.co:5432`) is IPv6-only and will fail from IPv4-only
# networks. Get the pooler URL from:
#   Supabase Dashboard → Project Settings → Database → Connection Pooling
#
# Session mode (port 5432) — required for Alembic migrations:
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
#
# Transaction mode (port 6543) — recommended for app runtime queries:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres

# Django secret key (generate a new one for production)
SECRET_KEY=change-me-in-production

# Set to False in production
DEBUG=True

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Supabase credentials (used by auth_ext for JWKS verification)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Redis URL for Django Channels
REDIS_URL=redis://localhost:6379/0
